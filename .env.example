# ============================================================================
# Adobe GenAI Creative Automation Platform - Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================================

# ============================================================================
# DATABASE
# ============================================================================

DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@localhost:5432/genai_platform

# ============================================================================
# REDIS
# ============================================================================

REDIS_URL=redis://localhost:6379

# ============================================================================
# JWT / AUTH
# ============================================================================

SECRET_KEY=

# ============================================================================
# IMAGE GENERATION BACKENDS
# At least ONE backend must be configured
# ============================================================================

# Adobe Firefly API
FIREFLY_API_KEY=
FIREFLY_CLIENT_ID=

# OpenAI API (DALL-E 3)
OPENAI_API_KEY=

# Google Gemini API (Imagen)
GEMINI_API_KEY=

# Anthropic Claude API (for guideline extraction & localization)
CLAUDE_API_KEY=

# Default image generation backend
# Options: firefly, openai, dalle, gemini, imagen
DEFAULT_IMAGE_BACKEND=firefly

# ============================================================================
# STORAGE
# ============================================================================

# Options: local, s3
STORAGE_BACKEND=local

# S3 / MinIO settings (required if STORAGE_BACKEND=s3)
S3_BUCKET=
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ============================================================================
# PERFORMANCE SETTINGS
# ============================================================================

MAX_CONCURRENT_REQUESTS=5
API_TIMEOUT=60
MAX_RETRIES=3

# ============================================================================
# APPLICATION
# ============================================================================

LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173

# ============================================================================
# FEATURE FLAGS
# ============================================================================

ENABLE_CLAUDE_INTEGRATION=true
ENABLE_EXTERNAL_GUIDELINES=true
ENABLE_LOCALIZATION=true

# ============================================================================
# PATHS
# ============================================================================

OUTPUT_DIR=./output
TEMP_DIR=./temp
