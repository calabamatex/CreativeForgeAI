# ============================================================================
# Adobe GenAI Creative Automation Platform - Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================================

# ============================================================================
# DATABASE
# ============================================================================
# Local dev: matches the Docker Compose `postgres` service (docker-compose.yml).
# The host port is remapped 5432 -> 5434 to avoid colliding with another local
# stack on :5432 (see docs/FOUND_ISSUES.md). These are non-secret local-dev
# creds; override with real credentials in production.

DATABASE_URL=postgresql+asyncpg://genai:genai_dev@localhost:5434/genai_platform

# ============================================================================
# REDIS
# ============================================================================
# Local dev: Docker Compose `redis` service, host port remapped 6379 -> 6380.

REDIS_URL=redis://localhost:6380/0

# ============================================================================
# JWT / AUTH
# ============================================================================

SECRET_KEY=

# ============================================================================
# RATE LIMITING  (P4-T2)
# ============================================================================
# Per-minute request limits, enforced via a Redis-backed fixed-window counter
# shared across all worker processes (keyed by user id when authenticated, else
# by client IP). If Redis is unavailable the limiter fails OPEN to a per-process
# in-memory fallback (availability over strictness).
RATE_LIMIT_AUTH=100
RATE_LIMIT_UNAUTH=20

# X-Forwarded-For handling. XFF is client-spoofable, so it is IGNORED by default
# and IP-based limits key on the socket peer (request.client.host). Enable ONLY
# when the app sits behind a trusted reverse proxy / load balancer that rewrites
# XFF, and list that proxy's IP(s) in TRUSTED_PROXIES. When trusted, the client
# IP is taken as the right-most XFF hop that is NOT a trusted proxy (the closest
# untrusted hop), which a spoofer cannot influence.
TRUST_FORWARDED_FOR=false
TRUSTED_PROXIES=

# ============================================================================
# IMAGE GENERATION BACKENDS
# At least ONE backend must be configured
# ============================================================================

# Adobe Firefly API
FIREFLY_API_KEY=
FIREFLY_CLIENT_ID=

# OpenAI API (DALL-E 3)
OPENAI_API_KEY=

# Google Gemini API (Imagen)
GEMINI_API_KEY=

# Anthropic Claude API (for guideline extraction & localization)
ANTHROPIC_API_KEY=

# Default image generation backend
# Options: firefly, openai, dalle, gemini, imagen
DEFAULT_IMAGE_BACKEND=firefly

# ============================================================================
# STORAGE
# ============================================================================

# Options: local, s3
STORAGE_BACKEND=local

# S3 / MinIO settings (required if STORAGE_BACKEND=s3)
# Local dev defaults point at the Docker Compose `minio` service. The S3 API
# host port is remapped 9000 -> 9002 (console 9001 -> 9003); the bucket
# `genai-assets` is created by the `minio-init` one-shot service on
# `docker compose up`. minioadmin/minioadmin are non-secret local-dev creds.
# Note: the S3 backend (src/storage_s3.py) authenticates via the standard boto3
# credential chain, so AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY must be set.
S3_BUCKET=genai-assets
S3_ENDPOINT_URL=http://localhost:9002
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# ============================================================================
# PERFORMANCE SETTINGS
# ============================================================================

MAX_CONCURRENT_REQUESTS=5
API_TIMEOUT=60
MAX_RETRIES=3

# ============================================================================
# APPLICATION
# ============================================================================

LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173

# ============================================================================
# FEATURE FLAGS
# ============================================================================

ENABLE_CLAUDE_INTEGRATION=true
ENABLE_EXTERNAL_GUIDELINES=true
ENABLE_LOCALIZATION=true

# ============================================================================
# PATHS
# ============================================================================

OUTPUT_DIR=./output
TEMP_DIR=./temp
